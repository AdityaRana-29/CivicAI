# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/civicai
# OR MongoDB Atlas (replace with your cluster URL)
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/civicai?retryWrites=true&w=majority

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=change_this_to_another_random_64_char_string
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail: enable 2FA, then create App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password

# ─── AI Thresholds ────────────────────────────────────────────────────────────
DUPLICATE_THRESHOLD=0.85
DUPLICATE_RADIUS_METERS=100
PREDICTION_MIN_CLUSTER_SIZE=5

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
